# =========================
# Ignore EVERYTHING
# =========================
*

# =========================
# Allow directory traversal
# (CRITICAL for whitelist)
# =========================
!backend/
!frontend/

# Allow traversal inside
!backend/**
!frontend/**

# =========================
# BACKEND (Python)
# =========================

# Allow ONLY python source + minimal config
!backend/**/*.py
!backend/requirements.txt
!backend/pyproject.toml

# Explicitly ignore Python junk
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd

# Virtual environment (never track)
backend/venv/

# =========================
# FRONTEND (Next.js)
# =========================

# Allow core config
!frontend/package.json
!frontend/package-lock.json
!frontend/next.config.js
!frontend/tsconfig.json

# Allow source folders
!frontend/app/
!frontend/app/**

!frontend/components/
!frontend/components/**

!frontend/public/
!frontend/public/**

!frontend/styles/
!frontend/styles/**

# Ignore frontend junk
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/

# =========================
# ROOT FILES
# =========================
!.gitignore
!README.md

# =========================
# GLOBAL JUNK (override everything)
# =========================

# Python cache (safety net)
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
*.log

# Env files
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/